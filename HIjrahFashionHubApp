// User: SITI ZULAIKA BINTI JAUFARI - - Main JavaFX application handling UI navigation, cart system and order processing
public class HijrahFashionHubApp extends Application {

    private Stage primaryStage;

    // User: SYAZANA - Abstraction & Inheritance module (User hierarchy storage)
    private final Map<String, User> userRegistry = new HashMap<>();
    private User currentUser;

    // User: SITI ZULAIKA - Product system for shop module
    private final ObservableList<Product> products = FXCollections.observableArrayList();
    private final ObservableList<Product> filteredProducts = FXCollections.observableArrayList();

    // User: SITI ZULAIKA - Cart and order tracking system
    private final ObservableList<Product> cart = FXCollections.observableArrayList();
    private final ObservableList<Order> orders = FXCollections.observableArrayList();

    // UI Tables
    private TableView<Product> productTable;
    private TableView<Product> cartTable;

    private Label totalLabel = new Label("Total: RM 0.00");

    private Scene loginScene, registerScene, homeScene, shopScene, adminScene;

    @Override
    public void start(Stage stage) {

        primaryStage = stage;

        userRegistry.put("admin", new Admin("admin", "123"));
        userRegistry.put("user", new Customer("user", "123"));

        setupProducts();
        filteredProducts.addAll(products);

        createLoginScene();
        createRegisterScene();
        createHomeScene();
        createShopScene();

        stage.setScene(loginScene);
        stage.setTitle("Hijrah Fashion Hub");
        stage.show();
    }

    // ================= LOGIN =================
    private void createLoginScene() {
        
        //make a login label first in a cluster so its easier to diffrentiate between button
        TextField u = new TextField();
        PasswordField p = new PasswordField();
        
        //login lable
        Label loginLabel = new Label("HIJRAH FASHION HUB LOGIN");
        loginLabel.setFont(Font.font("Arial Rounded MT Bold", FontWeight.BOLD, 40));
        loginLabel.setTextFill(Color.HOTPINK);
        //username label
        Label usernameLabel = new Label("Username:");
        usernameLabel.setTextFill(Color.HOTPINK);
      
       
        //pasword label
        Label passwordLabel = new Label("Password:");
        passwordLabel.setTextFill(Color.HOTPINK);
      
        
        
        
        //make a button
        Button login = new Button("Login");
        Button register = new Button("Register");

        // User: SITI ZULAIKA - Login validation logic
        login.setOnAction(e -> {
            if (userRegistry.containsKey(u.getText())
                    && userRegistry.get(u.getText()).getPassword().equals(p.getText())) {

                currentUser = userRegistry.get(u.getText());
                primaryStage.setScene(homeScene);

            } else {
                alert("Login Failed", "Wrong username/password");
            }
        });

        register.setOnAction(e -> primaryStage.setScene(registerScene));
        
        //make vbox
        VBox root = new VBox(10);
        root.setPadding(new Insets(20));
        root.setAlignment(Pos.CENTER);
        loginScene = new Scene(root, 700, 500);
        
        //make gridpane
     
        GridPane gridPane = new GridPane();
        gridPane.add(login, 0, 3);
        gridPane.add(register, 1, 3);
        gridPane.setAlignment(Pos.CENTER);
        gridPane.setPadding(new Insets(20));
        gridPane.setVgap(10);
        gridPane.setHgap(10);
        gridPane.add(loginLabel, 0, 0, 2, 1);
        GridPane.setHalignment(loginLabel, HPos.CENTER);
        gridPane.add(usernameLabel, 0, 1);
        gridPane.add(u, 1, 1);
        gridPane.add(passwordLabel, 0, 2);
        gridPane.add(p, 1, 2);
        gridPane.setStyle("-fx-background-color: #FFDDEB;");
        loginScene = new Scene(gridPane, 700, 500);
    }

    // ================= REGISTER =================
        private void createRegisterScene() {

           TextField u = new TextField();
           PasswordField p = new PasswordField();

           // make label
           Label title = new Label("HIJRAH FASHION HUB REGISTER");
           title.setStyle("-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: hotpink;");

           Label usernameLabel = new Label("Username:");
           usernameLabel.setTextFill(Color.HOTPINK);

           Label passwordLabel = new Label("Password:");
           passwordLabel.setTextFill(Color.HOTPINK);

           Label roleLabel = new Label("Role:");
           roleLabel.setTextFill(Color.HOTPINK);

           ComboBox<String> role = new ComboBox<>();
           role.getItems().addAll("Customer", "Admin");
           role.setValue("Customer");
           
           // make button 
           Button create = new Button("Create");
           Button back = new Button("Back");

         
           create.setOnAction(e -> {
               String username = u.getText();
               String password = p.getText();

               if (username.isEmpty() || password.isEmpty()) return;

               if (role.getValue().equals("Admin")) {
                   userRegistry.put(username, new Admin(username, password));
               } else {
                   userRegistry.put(username, new Customer(username, password));
               }

               primaryStage.setScene(loginScene);
           });

           back.setOnAction(e -> primaryStage.setScene(loginScene));

           //make gridpane
           GridPane grid = new GridPane();
           grid.setAlignment(Pos.CENTER);
           grid.setPadding(new Insets(20));
           grid.setHgap(10);
           grid.setVgap(10);

           // make tittle
           grid.add(title, 0, 0, 2, 1);
           GridPane.setHalignment(title, javafx.geometry.HPos.CENTER);

           grid.add(usernameLabel, 0, 1);
           grid.add(u, 1, 1);

           grid.add(passwordLabel, 0, 2);
           grid.add(p, 1, 2);

           grid.add(roleLabel, 0, 3);
           grid.add(role, 1, 3);

           grid.add(create, 0, 4);
           grid.add(back, 1, 4);

           GridPane.setHalignment(create, javafx.geometry.HPos.CENTER);
           GridPane.setHalignment(back, javafx.geometry.HPos.CENTER);

       
           grid.setStyle(
               "-fx-background-color: linear-gradient(to bottom, #ffe6f0, #ffd1dc);"
           );

           registerScene = new Scene(grid, 700, 500);
       }
    // ================= HOME =================
    private void createHomeScene() {
        
        //make label
        Label welcome = new Label("Welcome");
        welcome.setFont(Font.font("Arial Rounded MT Bold", FontWeight.BOLD, 30));
        welcome.setTextFill(Color.HOTPINK);

        //make button
        Button shop = new Button("Customer Shop");
        Button admin = new Button("Admin Panel");
        Button logout = new Button("Logout");

        shop.setOnAction(e -> primaryStage.setScene(shopScene));

        admin.setOnAction(e -> {
            if (currentUser instanceof Admin) {
                createAdminScene();
                primaryStage.setScene(adminScene);
            } else {
                alert("Denied", "Admin only");
            }
        });

        logout.setOnAction(e -> primaryStage.setScene(loginScene));
        
        //makevbox
        VBox root = new VBox(10, welcome, shop, admin, logout);
        root.setAlignment(Pos.CENTER);
        root.setStyle("-fx-background-color: #FFD1DC;");

        homeScene = new Scene(root, 400, 300);
    }

  
   
       // ================= SHOP =================
        private void createShopScene() {

            productTable = new TableView<>();
            cartTable = new TableView<>();

            // ================= PRODUCT TABLE =================
            TableColumn<Product, String> productNameCol = new TableColumn<>("Name");
            productNameCol.setCellValueFactory(new PropertyValueFactory<>("name"));

            TableColumn<Product, String> productCategoryCol = new TableColumn<>("Category");
            productCategoryCol.setCellValueFactory(new PropertyValueFactory<>("category"));

            TableColumn<Product, Double> productPriceCol = new TableColumn<>("Price");
            productPriceCol.setCellValueFactory(new PropertyValueFactory<>("price"));

            productTable.getColumns().addAll(productNameCol, productCategoryCol, productPriceCol);
            productTable.setItems(filteredProducts);

            // ================= CART TABLE =================
            TableColumn<Product, String> cartNameCol = new TableColumn<>("Name");
            cartNameCol.setCellValueFactory(new PropertyValueFactory<>("name"));

            TableColumn<Product, String> cartCategoryCol = new TableColumn<>("Category");
            cartCategoryCol.setCellValueFactory(new PropertyValueFactory<>("category"));

            TableColumn<Product, Double> cartPriceCol = new TableColumn<>("Price");
            cartPriceCol.setCellValueFactory(new PropertyValueFactory<>("price"));

            cartTable.getColumns().addAll(cartNameCol, cartCategoryCol, cartPriceCol);
            cartTable.setItems(cart);

            // ================= SEARCH & CATEGORY =================
            TextField search = new TextField();
            search.setPromptText("Search product");

            ComboBox<String> category = new ComboBox<>();
            category.getItems().addAll("All", "Abaya", "Hijab", "Jubah", "Accessory", "Set");
            category.setValue("All");

            search.textProperty().addListener((a, b, c) -> filter(c, category.getValue()));
            category.setOnAction(e -> filter(search.getText(), category.getValue()));

            // ================= BUTTONS =================
            Button add     = new Button("Add to Cart");
            Button remove  = new Button("Remove");
            Button order   = new Button("Place Order");
            Button invoice = new Button("View Invoice");   
            Button history = new Button("History");
            Button back    = new Button("Back");

            // Style the total label
            totalLabel.setStyle("-fx-font-size: 16px; -fx-font-weight: bold;");

            add.setOnAction(e -> {
                Product p = productTable.getSelectionModel().getSelectedItem();
                if (p != null) {
                    cart.add(p);
                    updateTotal();
                }
            });

            remove.setOnAction(e -> {
                Product p = cartTable.getSelectionModel().getSelectedItem();
                if (p != null) {
                    cart.remove(p);
                    updateTotal();
                }
            });

            order.setOnAction(e -> placeOrder());

           
            invoice.setOnAction(e -> {
                if (!cart.isEmpty()) {
                    double total = cart.stream().mapToDouble(Product::getPrice).sum();
                    Order preview = new Order(currentUser.getUsername(), new ArrayList<>(cart), total);
                    showInvoicePopup(preview);
                } else if (!orders.isEmpty()) {
                    // Show the last order placed by this user
                    Order lastOrder = null;
                    for (Order o : orders) {
                        if (o.getCustomer().equals(currentUser.getUsername())) {
                            lastOrder = o;
                        }
                    }
                    if (lastOrder != null) {
                        showInvoicePopup(lastOrder);
                    } else {
                        alert("No Invoice", "No orders found for your account.");
                    }
                } else {
                    alert("Empty", "Your cart is empty and you have no past orders.");
                }
            });

            history.setOnAction(e -> viewOrderHistory());
            back.setOnAction(e -> primaryStage.setScene(homeScene));

           
            productTable.setPrefWidth(450);
            cartTable.setPrefWidth(350);

            VBox left = new VBox(10,
                    new Label(" Products"),
                    search,
                    category,
                    productTable,
                    add
            );

           
            HBox totalRow = new HBox(15, totalLabel, invoice);
            totalRow.setAlignment(Pos.CENTER_LEFT);

            VBox right = new VBox(10,
                    new Label(" Your Cart"),
                    cartTable,
                    remove,
                    totalRow,       // total + invoice button side by side
                    order,
                    history,
                    back
            );

            HBox root = new HBox(20, left, right);
            root.setStyle("-fx-background-color: #FFD1DC;");

            root.setPadding(new Insets(10));

            shopScene = new Scene(root, 900, 500);
        }
          // ================= ADMIN =================
          private void createAdminScene() {
              TableView<Product> table = new TableView<>();
              table.setItems(products);
              TableColumn<Product,String> n = new TableColumn<>("Name");
              n.setCellValueFactory(new PropertyValueFactory<>("name"));
              TableColumn<Product,Double> p = new TableColumn<>("Price");
              p.setCellValueFactory(new PropertyValueFactory<>("price"));
              table.getColumns().addAll(n,p);
              TextField name = new TextField();
              TextField price = new TextField();
              Button add = new Button("Add");
              Button delete = new Button("Delete");
              Button back = new Button("Back");
              add.setOnAction(e ->
                      products.add(new Product(name.getText(),"",Double.parseDouble(price.getText()))));
              delete.setOnAction(e -> {
                  Product selected = table.getSelectionModel().getSelectedItem();
                  if (selected != null) products.remove(selected);
              });
              back.setOnAction(e -> primaryStage.setScene(homeScene));
              VBox root = new VBox(10, table, name, price, add, delete, back);
                root.setStyle("-fx-background-color: #FFD1DC;");

              adminScene = new Scene(root, 600, 400);
          }
          // ================= ORDER =================
          private void placeOrder() {
          if (cart.isEmpty()) return;
          double total = cart.stream().mapToDouble(Product::getPrice).sum();
          Order order = new Order(
                  currentUser.getUsername(),
                  new ArrayList<>(cart),
                  total
          );
          orders.add(order);
          // save file invoice (optional still keep)
          saveInvoice(order);
         
          showInvoicePopup(order);
          cart.clear();
          updateTotal();
          alert("Success", "Order placed!");
      }
          // ================= ORDER HISTORY =================
          private void viewOrderHistory() {
              ObservableList<Order> myOrders = FXCollections.observableArrayList();
              for (Order o : orders) {
                  if (o.getCustomer().equals(currentUser.getUsername())) {
                      myOrders.add(o);
                  }
              }
              TableView<Order> table = new TableView<>();
              TableColumn<Order,String> c = new TableColumn<>("Customer");
              c.setCellValueFactory(new PropertyValueFactory<>("customer"));
              TableColumn<Order,Double> t = new TableColumn<>("Total");
              t.setCellValueFactory(new PropertyValueFactory<>("total"));
              table.getColumns().addAll(c,t);
              table.setItems(myOrders);
              Button back = new Button("Back");
              back.setOnAction(e -> primaryStage.setScene(shopScene));
              VBox root = new VBox(10, table, back);
              primaryStage.setScene(new Scene(root,500,400));
          }
          // ================= FILTER =================
          private void filter(String keyword, String cat) {
              filteredProducts.clear();
              for (Product p : products) {
                  boolean okName = p.getName().toLowerCase().contains(keyword.toLowerCase());
                  boolean okCat = cat.equals("All") || p.getCategory().equals(cat);
                  if (okName && okCat) filteredProducts.add(p);
              }
          }
          // ================= PRODUCTS =================
          private void setupProducts() {
              products.addAll(
                      new Product("Abaya","Abaya",120),
                      new Product("Hijab","Hijab",45),
                      new Product("Jubah","Jubah",150),
                      new Product("Bag","Accessory",60)
              );
          }
          // ================= INVOICE (FULL DETAIL) =================
      private void saveInvoice(Order order) {
          try (PrintWriter pw = new PrintWriter(new FileWriter("invoice.txt", true))) {
              pw.println("==================================");
              pw.println("        HIJRAH FASHION HUB       ");
              pw.println("==================================");
              pw.println("Customer : " + order.getCustomer());
              pw.println("\nItems:");
              for (Product p : order.getItems()) {
                  pw.println("- " + p.getName()
                          + " (" + p.getCategory() + ")"
                          + " RM " + p.getPrice());
              }
              pw.println("\nTOTAL: RM " + order.getTotal());
              DateTimeFormatter dtf = DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss");
              pw.println("Date: " + LocalDateTime.now().format(dtf));
              pw.println("==================================\n");
          } catch (Exception e) {
              System.out.println("Invoice error: " + e.getMessage());
          }
      }
      // ================= POPUP INVOICE =================
      private void showInvoicePopup(Order order) {
          StringBuilder items = new StringBuilder();
          for (Product p : order.getItems()) {
              items.append(p.getName())
                      .append(" | ")
                      .append(p.getCategory())
                      .append(" | RM ")
                      .append(p.getPrice())
                      .append("\n");
          }
          DateTimeFormatter dtf =
                  DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss");
          Label title = new Label(" INVOICE RECEIPT");
          title.setStyle("-fx-font-size: 18px; -fx-font-weight: bold;");
          Label customer = new Label("Customer: " + order.getCustomer());
          Label itemList = new Label(items.toString());
          Label total = new Label("TOTAL: RM " + order.getTotal());
          Label date = new Label("Date: " + LocalDateTime.now().format(dtf));
          Button close = new Button("Close");
          VBox root = new VBox(10,
                  title,
                  customer,
                  itemList,
                  total,
                  date,
                  close
          );
          root.setPadding(new Insets(15));
          root.setAlignment(Pos.CENTER);
          Stage popup = new Stage();
          popup.setTitle("Invoice");
          popup.setScene(new Scene(root, 350, 400));
          close.setOnAction(e -> popup.close());
          popup.show();
      }
          // ================= TOTAL =================
          private void updateTotal() {
              double t = cart.stream().mapToDouble(Product::getPrice).sum();
              totalLabel.setText("Total: RM " + t);
          }
          // ================= ALERT =================
          private void alert(String t, String m) {
              Alert a = new Alert(Alert.AlertType.INFORMATION);
              a.setTitle(t);
              a.setContentText(m);
              a.show();
          }
      }
