package javafxhijrahfashionhub;

import javafx.application.Application;
import javafx.collections.*;
import javafx.geometry.*;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.control.cell.PropertyValueFactory;
import javafx.scene.layout.*;
import javafx.stage.Stage;

import java.util.*;

public class HijrahFashionHubApp extends Application {

    private Stage primaryStage;

    // USERS
    private final Map<String, User> userRegistry = new HashMap<>();
    private User currentUser;

    // PRODUCTS
    private final ObservableList<Product> products = FXCollections.observableArrayList();
    private final ObservableList<Product> cart = FXCollections.observableArrayList();

    // TABLES
    private TableView<Product> productTable = new TableView<>();
    private TableView<Product> cartTable = new TableView<>();

    private Label totalLabel = new Label("Total: RM 0.00");
    private Label welcomeLabel = new Label();

    private Scene loginScene, registerScene, homeScene, shopScene, adminScene;

    @Override
    public void start(Stage stage) {

        primaryStage = stage;
        stage.setTitle("Hijrah Fashion Hub");

        userRegistry.put("admin", new Admin("admin", "123"));
        userRegistry.put("user", new Customer("user", "123"));

        setupProducts();   // ⭐ MUST CALL FIRST

        createLoginScene();
        createRegisterScene();
        createHomeScene();
        createShopScene();

        stage.setScene(loginScene);
        stage.show();
    }

    // ================= LOGIN =================
    private void createLoginScene() {

        TextField u = new TextField();
        PasswordField p = new PasswordField();

        Button login = new Button("Login");
        Button register = new Button("Register");

        login.setOnAction(e -> {
            if (userRegistry.containsKey(u.getText())
                    && userRegistry.get(u.getText()).getPassword().equals(p.getText())) {

                currentUser = userRegistry.get(u.getText());
                welcomeLabel.setText("Welcome " + currentUser.getUsername());

                primaryStage.setScene(homeScene);

            } else {
                alert("Login Failed", "Wrong username/password");
            }
        });

        register.setOnAction(e -> primaryStage.setScene(registerScene));

        VBox root = new VBox(10, new Label("LOGIN"), u, p, login, register);
        root.setAlignment(Pos.CENTER);

        loginScene = new Scene(root, 400, 300);
    }

    // ================= REGISTER =================
    private void createRegisterScene() {

        TextField u = new TextField();
        PasswordField p = new PasswordField();

        ComboBox<String> role = new ComboBox<>();
        role.getItems().addAll("Customer", "Admin");
        role.setValue("Customer");

        Button create = new Button("Create");
        Button back = new Button("Back");

        create.setOnAction(e -> {

            if (role.getValue().equals("Admin")) {
                userRegistry.put(u.getText(), new Admin(u.getText(), p.getText()));
            } else {
                userRegistry.put(u.getText(), new Customer(u.getText(), p.getText()));
            }

            alert("Success", "Account created");
            primaryStage.setScene(loginScene);
        });

        back.setOnAction(e -> primaryStage.setScene(loginScene));

        VBox root = new VBox(10, new Label("REGISTER"), u, p, role, create, back);
        root.setAlignment(Pos.CENTER);

        registerScene = new Scene(root, 400, 300);
    }

    // ================= HOME =================
    private void createHomeScene() {

        Button shop = new Button("Customer Shop");
        Button admin = new Button("Admin Panel");
        Button logout = new Button("Logout");

        shop.setOnAction(e -> {
            refreshTable();   // ⭐ IMPORTANT FIX
            primaryStage.setScene(shopScene);
        });

        admin.setOnAction(e -> {
            createAdminScene();
            primaryStage.setScene(adminScene);
        });

        logout.setOnAction(e -> primaryStage.setScene(loginScene));

        VBox root = new VBox(10, welcomeLabel, shop, admin, logout);
        root.setAlignment(Pos.CENTER);

        homeScene = new Scene(root, 400, 300);
    }

    // ================= SHOP =================
    // ================= SHOP (CUSTOMER) =================
private void createShopScene() {

    setupTables();

    TextField search = new TextField();
    search.setPromptText("Search product...");

    ComboBox<String> category = new ComboBox<>();
    category.getItems().addAll(
            "All",
            "Abaya",
            "Hijab",
            "Jubah",
            "Set",
            "Accessory"
    );
    category.setValue("All");

    search.textProperty().addListener((obs, oldValue, newValue) ->
            filter(newValue, category.getValue()));

    category.setOnAction(e ->
            filter(search.getText(), category.getValue()));

    Button add = new Button("Add to Cart");
    Button remove = new Button("Remove");
    Button checkout = new Button("Place Order");
    Button back = new Button("Back");

    add.setOnAction(e -> {

        Product selected =
                productTable.getSelectionModel().getSelectedItem();

        if (selected != null) {
            cart.add(selected);
            updateTotal();
        }
    });

    remove.setOnAction(e -> {

        Product selected =
                cartTable.getSelectionModel().getSelectedItem();

        if (selected != null) {
            cart.remove(selected);
            updateTotal();
        }
    });

    checkout.setOnAction(e -> {

        if (cart.isEmpty()) {
            alert("Empty", "Cart kosong");
            return;
        }

        double total = cart.stream()
                .mapToDouble(Product::getPrice)
                .sum();

        Order order = new Order(
                currentUser.getUsername(),
                new ArrayList<>(cart),
                total
        );

        orders.add(order);

        showInvoice(order);

        cart.clear();
        updateTotal();
    });

    back.setOnAction(e ->
            primaryStage.setScene(homeScene));

    VBox left = new VBox(
            10,
            search,
            category,
            productTable,
            add
    );

    VBox right = new VBox(
            10,
            cartTable,
            remove,
            totalLabel,
            checkout,
            back
    );

    left.setPrefWidth(450);
    right.setPrefWidth(350);

    productTable.setPrefHeight(350);
    cartTable.setPrefHeight(350);

    HBox root = new HBox(20, left, right);
    root.setPadding(new Insets(10));

    shopScene = new Scene(root, 900, 500);
}

    // ================= ADMIN =================
    private void createAdminScene() {

        TableView<Product> table = new TableView<>();
        table.setItems(products);

        TableColumn<Product, String> n = new TableColumn<>("Name");
        n.setCellValueFactory(new PropertyValueFactory<>("name"));

        TableColumn<Product, String> c = new TableColumn<>("Category");
        c.setCellValueFactory(new PropertyValueFactory<>("category"));

        TableColumn<Product, Double> p = new TableColumn<>("Price");
        p.setCellValueFactory(new PropertyValueFactory<>("price"));

        table.getColumns().setAll(n, c, p);

        TextField name = new TextField();
        TextField cat = new TextField();
        TextField price = new TextField();

        Button add = new Button("Add");
        Button delete = new Button("Delete");
        Button back = new Button("Back");

        add.setOnAction(e -> {
            products.add(new Product(name.getText(), cat.getText(),
                    Double.parseDouble(price.getText())));
            refreshTable();
        });

        delete.setOnAction(e -> {
            Product selected = table.getSelectionModel().getSelectedItem();
            if (selected != null) {
                products.remove(selected);
                refreshTable();
            }
        });

        back.setOnAction(e -> primaryStage.setScene(homeScene));

        VBox form = new VBox(10, name, cat, price, add, delete, back);
        HBox root = new HBox(20, table, form);

        adminScene = new Scene(root, 800, 500);
    }

     
    // ================= FILTER =================
    private void filter(String keyword, String category) {

        ObservableList<Product> temp = FXCollections.observableArrayList();

        for (Product p : products) {

            boolean matchName = p.getName().toLowerCase()
                    .contains(keyword.toLowerCase());

            boolean matchCat = category.equals("All")
                    || p.getCategory().equals(category);

            if (matchName && matchCat) temp.add(p);
        }

        productTable.setItems(temp);
    }

    // ⭐ FIX CUSTOMER EMPTY PRODUCT BUG
    private void refreshTable() {
        productTable.setItems(products);
    }

    // ================= TABLE =================
    // ================= TABLE =================
private void setupTables() {

    // Clear old columns
    productTable.getColumns().clear();
    cartTable.getColumns().clear();

    // ---------- PRODUCT TABLE ----------

    TableColumn<Product, String> productName =
            new TableColumn<>("Name");
    productName.setCellValueFactory(
            new PropertyValueFactory<>("name"));

    TableColumn<Product, String> productCategory =
            new TableColumn<>("Category");
    productCategory.setCellValueFactory(
            new PropertyValueFactory<>("category"));

    TableColumn<Product, Double> productPrice =
            new TableColumn<>("Price");
    productPrice.setCellValueFactory(
            new PropertyValueFactory<>("price"));

    productTable.getColumns().addAll(
            productName,
            productCategory,
            productPrice
    );

    productTable.setItems(products);

    // ---------- CART TABLE ----------

    TableColumn<Product, String> cartName =
            new TableColumn<>("Name");
    cartName.setCellValueFactory(
            new PropertyValueFactory<>("name"));

    TableColumn<Product, Double> cartPrice =
            new TableColumn<>("Price");
    cartPrice.setCellValueFactory(
            new PropertyValueFactory<>("price"));

    cartTable.getColumns().addAll(
            cartName,
            cartPrice
    );

    cartTable.setItems(cart);
}

    // ================= PRODUCTS =================
    private void setupProducts() {

        products.addAll(
                new Product("Abaya", "Abaya", 120),
                new Product("Hijab", "Hijab", 45),
                new Product("Jubah", "Jubah", 150),
                new Product("Scarf", "Accessory", 25),
                new Product("Bag", "Accessory", 60),
                new Product("Shoes", "Accessory", 90),
                new Product("Gift Box", "Set", 200)
        );
    }

    // ================= TOTAL =================
    private void updateTotal() {
        totalLabel.setText("Total: RM " +
                cart.stream().mapToDouble(Product::getPrice).sum());
    }

    // ================= ALERT =================
    private void alert(String t, String m) {
        Alert a = new Alert(Alert.AlertType.INFORMATION);
        a.setTitle(t);
        a.setContentText(m);
        a.show();
    }
}
